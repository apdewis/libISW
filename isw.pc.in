prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: ISW
Description: Infi Systems Widgets - XCB-based 3D widget library
Version: @PACKAGE_VERSION@
Requires: xproto xmu xt
Requires.private: x11 xext xcb xcb-xfixes xcb-render xcb-shape xft
Cflags: -I${includedir} @ISW_CPPFLAGS@
Libs: -L${libdir} -lISW
