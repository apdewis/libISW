AM_YFLAGS = -d -p LayYY
AM_CFLAGS = \
	$(CWARNFLAGS) \
	$(XT_DEPS_CFLAGS) \
	$(ISW_DEPS_CFLAGS) \
	$(XPM_CFLAGS) \
	$(XKBCOMMON_CFLAGS) \
	$(CAIRO_CFLAGS) \
