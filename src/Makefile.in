	$(FREETYPE_CFLAGS) \
	$(EGL_CFLAGS) \
	$(CAIRO_GL_CFLAGS) \
	$(SRCH_DEFINES) \
	$(ERRORDB_DEFINES)


# Header include order: local includes first, then generated
AM_CPPFLAGS = \
	-I$(top_srcdir)/include \
	-I$(top_srcdir)/include/X11 \
	-I$(top_builddir)/include/X11 \
	$(ISW_CPPFLAGS) \
	-DLIBXT_COMPILATION


# LibXt source files (from X Toolkit Intrinsics)
LIBXT_SOURCES = \
	ActionHook.c \
	Alloc.c \
	ArgList.c \
